generator client {
  provider = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id           Int       @id @default(autoincrement())
  nom          String    @unique
  localisation String?  
  managers     Manager[]
  rapports     Report[]
}

model Manager {
  jid              String            @id
  nom              String            
  role             String            @default("Manager")
  shopId           Int?
  shop             Shop?             @relation(fields: [shopId], references: [id])
  rapports         Report[]
  incidentsCloture IncidentCloture[] // 👈 Nouveau lien pour tracker qui doit quoi
  visites          VisiteTerrain[]   // 👈 Lien vers les visites terrain
  penalites        Penalite[]        // 👈 Lien vers les pénalités
}

model Message {
  id         String    @id @default(uuid())
  groupeJid  String
  senderJid  String
  texte      String    @db.Text
  estMedia   Boolean   @default(false)
  timestamp  DateTime  @default(now())
  incident   Incident?
  est_traite Boolean   @default(false)
}

model Report {
  id         String    @id @default(uuid())
  type       String
  contenu    Json
  complet    Boolean   @default(true)
  timestamp  DateTime  @default(now())
  managerJid String
  manager    Manager   @relation(fields: [managerJid], references: [jid])
  shopId     Int?
  shop       Shop?     @relation(fields: [shopId], references: [id])
}

model Incident {
  id          String    @id @default(uuid())
  type        String
  priorite    Int
  description String    @db.Text
  statut      String    @default("OUVERT")
  timestamp   DateTime  @default(now())
  messageId   String    @unique
  message     Message   @relation(fields: [messageId], references: [id])
}

// ==========================================
// 🚨 SUIVI DES NON-CLÔTURÉS
// ==========================================
model IncidentCloture {
  id              String    @id @default(uuid())
  machineId       String    // L'ID de la machine (ex: 342135)
  montant         String?   // Le montant retenu (ex: 337950)
  statut          String    @default("NON_RESOLU") 
  dateDeclaration DateTime  @default(now())
  dateResolution  DateTime? // Sera rempli quand le manager annoncera "résolu"
  managerJid      String
  manager         Manager   @relation(fields: [managerJid], references: [jid])
}

// ==========================================
// 📍 GESTION DES VISITES SUR LE TERRAIN
// ==========================================
model VisiteTerrain {
  id          Int      @id @default(autoincrement())
  agentId     String   
  branche     String   
  pdv         String   
  statut      String   
  tickets     Int      
  heureVisite String   
  texteBrut   String   @db.Text
  dateVisite  DateTime @default(now())
  
  // 🔗 Relation avec le Manager (Contrôleur)
  managerJid  String
  manager     Manager  @relation(fields: [managerJid], references: [jid])
}

// ==========================================
// 🚨 GESTION DES PÉNALITÉS
// ==========================================
model Penalite {
  id          Int      @id @default(autoincrement())
  agentId     String   
  branche     String   
  motif       String   
  montant     String   
  texteBrut   String   @db.Text
  dateSaisie  DateTime @default(now())
  
  // 🔗 Relation avec le Manager (Contrôleur)
  managerJid  String
  manager     Manager  @relation(fields: [managerJid], references: [jid])
}

view top_agents_visites {
  nom_manager   String?
  jid           String  @unique
  total_visites Int
}

view top_ventes_tickets {
  nom_manager   String?
  jid           String  @unique
  total_tickets Int
}

view alertes_terrain {
  id            Int      @unique
  nom_manager   String?
  agentId       String
  pdv           String
  statut        String
  heureVisite   String
  dateVisite    DateTime
}
